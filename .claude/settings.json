{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Read(**/.env.example)",
      "Read(**/.env.sample)",
      "Read(**/.env.template)",
      "Bash(./scripts/new-feature.sh:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)"
    ]
  }
}
